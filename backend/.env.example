# ── core-service (.env) ───────────────────────────────────────────────
# 아기·기록 등 도메인 서비스. JWT 는 검증만 한다(발급은 auth-service).

# --- DB ---
DATABASE_URL=sqlite+aiosqlite:///./muknoljam.db

# --- AI (없으면 AI 리뷰 비활성) ---
ANTHROPIC_API_KEY=

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- JWT (auth-service 와 반드시 동일한 값) ---
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- 내부 호출 보호 (auth-service 와 동일한 값) ---
INTERNAL_API_KEY=change-me-internal-key

# --- dev (true 면 토큰 없이 DEV_USER_ID 로 동작) ---
DEV_MODE=true
