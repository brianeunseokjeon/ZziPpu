{
  "$schema": "https://design-tokens.org/tr/",
  "$meta": {
    "name": "zzippu-design-tokens",
    "description": "먹놀잠(찌뿌둥) 크로스플랫폼 디자인 토큰 단일 원천(Single Source of Truth). SwiftUI(iOS)·Web(CSS 변수/Tailwind)·향후 SSR이 공유한다. 3계층: primitive → semantic → component. semantic/component는 라이트/다크 두 모드를 가진다. 피처 코드는 primitive를 직접 참조하지 않는다 — 반드시 semantic 또는 component 토큰만 사용.",
    "version": "1.0.0",
    "modes": ["light", "dark"],
    "namingConvention": "kebab 경로를 dot으로 표기. 예: semantic.color.domain.feeding.formula. 플랫폼 생성기가 이 경로를 각 언어 관례로 변환(SwiftUI: Theme.color.domain.feedingFormula / CSS: --color-domain-feeding-formula)."
  },

  "primitive": {
    "$description": "원시 팔레트·스케일. 값의 저장소일 뿐 의미 없음. 절대 피처에서 직접 쓰지 않는다. 값 출처: 웹 globals.css + Tailwind 실제 사용 클래스 환산 + STOOL_COLORS(constants.ts).",

    "color": {
      "$description": "Tailwind 팔레트에서 실제 사용된 색조만 승격. 이름은 Tailwind 관례(색상-명도).",
      "white": { "value": "#FFFFFF" },
      "black": { "value": "#000000" },
      "gray": {
        "50": { "value": "#F9FAFB", "$comment": "웹 --background" },
        "100": { "value": "#F3F4F6" },
        "200": { "value": "#E5E7EB" },
        "300": { "value": "#D1D5DB" },
        "400": { "value": "#9CA3AF" },
        "500": { "value": "#6B7280" },
        "600": { "value": "#4B5563" },
        "700": { "value": "#374151" },
        "800": { "value": "#1F2937" },
        "900": { "value": "#111827", "$comment": "웹 --foreground" }
      },
      "blue": {
        "50": { "value": "#EFF6FF" },
        "100": { "value": "#DBEAFE" },
        "300": { "value": "#93C5FD" },
        "400": { "value": "#60A5FA", "$comment": "primary base (버튼 기본)" },
        "500": { "value": "#3B82F6", "$comment": "primary hover/active·수유 도트·탭 활성" },
        "600": { "value": "#2563EB" },
        "700": { "value": "#1D4ED8", "$comment": "분유 퀵버튼 idle 글자" },
        "800": { "value": "#1E40AF", "$comment": "분유 퀵버튼 active 글자" }
      },
      "pink": {
        "50": { "value": "#FDF2F8", "$comment": "모유 퀵버튼 idle 배경" },
        "100": { "value": "#FCE7F3" },
        "300": { "value": "#F9A8D4", "$comment": "모유 퀵버튼 active 테두리" },
        "400": { "value": "#F472B6", "$comment": "모유 도트·여아 아바타" },
        "500": { "value": "#EC4899" },
        "600": { "value": "#DB2777", "$comment": "모유 양쪽(breastBoth) — sleep(purple)과 충돌 방지용 확정값" },
        "700": { "value": "#BE185D", "$comment": "모유 퀵버튼 idle 글자" },
        "800": { "value": "#9D174D", "$comment": "모유 퀵버튼 active 글자" }
      },
      "purple": {
        "50": { "value": "#FAF5FF" },
        "100": { "value": "#F3E8FF" },
        "300": { "value": "#D8B4FE", "$comment": "수면 퀵버튼 active 테두리" },
        "400": { "value": "#C084FC", "$comment": "수면 도트" },
        "500": { "value": "#A855F7" },
        "700": { "value": "#7E22CE", "$comment": "수면 퀵버튼 idle 글자" },
        "800": { "value": "#6B21A8", "$comment": "수면 퀵버튼 active 글자" }
      },
      "green": {
        "50": { "value": "#F0FDF4" },
        "100": { "value": "#DCFCE7" },
        "300": { "value": "#86EFAC", "$comment": "터미타임 퀵버튼 active 테두리" },
        "400": { "value": "#4ADE80", "$comment": "놀이 도트·대변 녹색" },
        "500": { "value": "#22C55E" },
        "700": { "value": "#15803D", "$comment": "터미타임 퀵버튼 idle 글자" },
        "800": { "value": "#166534", "$comment": "터미타임 퀵버튼 active 글자" }
      },
      "emerald": {
        "100": { "value": "#D1FAE5" },
        "400": { "value": "#34D399", "$comment": "게이지 적정 채움" },
        "600": { "value": "#059669" },
        "700": { "value": "#047857" }
      },
      "amber": {
        "50": { "value": "#FFFBEB" },
        "100": { "value": "#FEF3C7" },
        "400": { "value": "#FBBF24", "$comment": "게이지 부족 채움" },
        "500": { "value": "#F59E0B" },
        "600": { "value": "#D97706" },
        "700": { "value": "#B45309" }
      },
      "orange": {
        "50": { "value": "#FFF7ED" },
        "100": { "value": "#FFEDD5" },
        "400": { "value": "#FB923C", "$comment": "기저귀(둘다) 도트" },
        "700": { "value": "#C2410C" }
      },
      "red": {
        "50": { "value": "#FEF2F2" },
        "100": { "value": "#FEE2E2" },
        "400": { "value": "#F87171", "$comment": "destructive base" },
        "500": { "value": "#EF4444", "$comment": "대변 붉은색(경고)" },
        "600": { "value": "#DC2626" },
        "700": { "value": "#B91C1C" }
      },
      "rose": {
        "100": { "value": "#FFE4E6" },
        "400": { "value": "#FB7185", "$comment": "게이지 초과 채움" },
        "600": { "value": "#E11D48" },
        "700": { "value": "#BE123C" }
      },
      "cyan": {
        "50": { "value": "#ECFEFF", "$comment": "소변 퀵버튼 idle 배경" },
        "100": { "value": "#CFFAFE", "$comment": "소변 퀵버튼 active 배경" },
        "300": { "value": "#67E8F9", "$comment": "소변 퀵버튼 active 테두리" },
        "400": { "value": "#22D3EE", "$comment": "기저귀(소변) 도트" },
        "700": { "value": "#0E7490", "$comment": "소변 퀵버튼 idle 글자" },
        "800": { "value": "#155E75", "$comment": "소변 퀵버튼 active 글자" }
      },
      "yellow": {
        "50": { "value": "#FEFCE8", "$comment": "대변 퀵버튼 idle 배경" },
        "100": { "value": "#FEF9C3", "$comment": "대변 퀵버튼 active 배경" },
        "300": { "value": "#FCD34D", "$comment": "대변 노란색(정상)·대변 퀵버튼 active 테두리" },
        "500": { "value": "#EAB308", "$comment": "대변 도트(대변)" },
        "700": { "value": "#A16207", "$comment": "대변 퀵버튼 idle 글자" },
        "800": { "value": "#854D0E", "$comment": "대변 퀵버튼 active 글자" }
      },
      "brown": {
        "600": { "value": "#A16207", "$comment": "대변 갈색" }
      },
      "sky": {
        "200": { "value": "#BAE6FD", "$comment": "남아 아바타" }
      }
    },

    "space": {
      "$description": "4pt 그리드. 웹 Tailwind 간격(p-1..p-8) 및 iOS AppSpacing과 정렬.",
      "0": { "value": 0 },
      "1": { "value": 4, "$comment": "gap-1 / xs" },
      "1_5": { "value": 6, "$comment": "statusPill paddingY — 납작함 해소" },
      "2": { "value": 8, "$comment": "sm" },
      "3": { "value": 12, "$comment": "카드 내부 stat 패딩·타임라인 gap" },
      "3_5": { "value": 14, "$comment": "chip paddingX — 알약 비율" },
      "4": { "value": 16, "$comment": "md·페이지 좌우 패딩 px-4" },
      "5": { "value": 20, "$comment": "카드 패딩 p-5" },
      "6": { "value": 24, "$comment": "lg" },
      "8": { "value": 32, "$comment": "xl" },
      "10": { "value": 40 },
      "12": { "value": 48, "$comment": "xxl" }
    },

    "radius": {
      "$description": "웹 실제: input/button=xl(12), card=2xl(16), sheet=3xl(24), pill=full.",
      "none": { "value": 0 },
      "sm": { "value": 8 },
      "md": { "value": 12, "$comment": "rounded-xl — 버튼·인풋(44pt 컨트롤)" },
      "controlLg": { "value": 16, "$comment": "56pt 대형 버튼·BigActionButton 전용 — 각짐 완화" },
      "lg": { "value": 16, "$comment": "rounded-2xl — 카드·stat 타일" },
      "xl": { "value": 24, "$comment": "rounded-3xl — 바텀시트" },
      "full": { "value": 9999, "$comment": "pill·badge·아바타·도트" }
    },

    "size": {
      "$description": "터치타깃·컨트롤 높이. 신생아앱: 한손·초단위 기록 → 최소 44pt.",
      "touchMin": { "value": 44, "$comment": "WCAG/HIG 최소 터치타깃. 버튼 min-w/h" },
      "controlSm": { "value": 36, "$comment": "h-9" },
      "controlMd": { "value": 44, "$comment": "h-11 기본 버튼·인풋" },
      "controlLg": { "value": 56, "$comment": "h-14 주요 액션·탭바 높이" },
      "dotSm": { "value": 8 },
      "dotMd": { "value": 10 },
      "iconSm": { "value": 14 },
      "iconMd": { "value": 20 },
      "iconLg": { "value": 24 }
    },

    "font": {
      "$description": "iOS는 SF(system) + Dynamic Type. 웹은 -apple-system 스택. size는 Dynamic Type 매핑 참고용 기준값(pt), weight는 공통.",
      "family": {
        "system": { "value": "-apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif" },
        "mono": { "value": "ui-monospace, SFMono-Regular, Menlo, monospace", "$comment": "타임라인 시각 tabular" }
      },
      "weight": {
        "regular": { "value": 400 },
        "medium": { "value": 500 },
        "semibold": { "value": 600 },
        "bold": { "value": 700 }
      },
      "scale": {
        "$description": "값=고정 pt. iOS 생성기는 .system(size:weight:) 고정 pt로 방출(웹 px 1:1 수렴, Dynamic Type은 뷰단 상한만). 웹은 rem으로.",
        "caption2": { "value": 12, "$comment": "label/mono 하한 승격 11→12(신생아 가독성, 12 미만 금지)" },
        "caption": { "value": 12, "$comment": "보조 텍스트 text-xs" },
        "footnote": { "value": 13 },
        "subheadline": { "value": 15 },
        "callout": { "value": 14, "$comment": "본문 통일 text-sm. 인풋 자동줌 방지값은 input.minFontSize(16 고정)로 분리" },
        "body": { "value": 14, "$comment": "웹 본문 text-sm — 최다 사용" },
        "headline": { "value": 16, "$comment": "text-base — 카드 소제목" },
        "title3": { "value": 18, "$comment": "카드 타이틀 text-lg" },
        "title2": { "value": 22 },
        "title1": { "value": 28 },
        "display": { "value": 36, "$comment": "대시보드 큰 숫자 text-4xl tabular" }
      },
      "lineHeight": {
        "tight": { "value": 1.15 },
        "normal": { "value": 1.4 },
        "relaxed": { "value": 1.6 }
      }
    },

    "shadow": {
      "$description": "웹 shadow-sm/lg/xl 환산. iOS는 color+opacity+radius+y로 매핑.",
      "none": { "value": { "x": 0, "y": 0, "blur": 0, "spread": 0, "color": "transparent", "opacity": 0 } },
      "sm": { "value": { "x": 0, "y": 2, "blur": 8, "spread": 0, "color": "#000000", "opacity": 0.06 }, "$comment": "카드 부양 — 넓고 옅게(iOS식)" },
      "md": { "value": { "x": 0, "y": 4, "blur": 16, "spread": -1, "color": "#000000", "opacity": 0.08 } },
      "lg": { "value": { "x": 0, "y": 8, "blur": 24, "spread": -3, "color": "#000000", "opacity": 0.10 }, "$comment": "토스트·플로팅 배지" },
      "xl": { "value": { "x": 0, "y": 20, "blur": 25, "spread": -5, "color": "#000000", "opacity": 0.12 }, "$comment": "바텀시트" }
    },

    "motion": {
      "$description": "전환 시간·이징·전용 지속. 신생아앱은 과한 애니 지양(성능·주의분산). prefers-reduced-motion 존중.",
      "duration": {
        "instant": { "value": 100 },
        "fast": { "value": 200, "$comment": "버튼/토스트 slideUp" },
        "normal": { "value": 300 },
        "slow": { "value": 500 }
      },
      "easing": {
        "standard": { "value": "cubic-bezier(0.2, 0, 0, 1)", "$comment": "iOS: .easeOut 근사" },
        "decelerate": { "value": "cubic-bezier(0, 0, 0.2, 1)" },
        "spring": { "value": { "response": 0.35, "dampingFraction": 0.85 }, "$comment": "SwiftUI .spring — 바텀시트/토글" }
      },
      "toastAutoDismissMs": { "value": 3500 }
    },

    "opacity": {
      "disabled": { "value": 0.5 },
      "muted": { "value": 0.3, "$comment": "비활성 네비 버튼" },
      "scrim": { "value": 0.4, "$comment": "바텀시트 배경 딤" }
    }
  },

  "semantic": {
    "$description": "역할 기반 토큰. 피처가 실제로 참조하는 층. 각 토큰은 {light, dark} 두 값을 primitive 참조로 가진다. 참조 표기 '{primitive.color.gray.50}'는 생성기가 해석.",

    "color": {
      "background": {
        "$description": "앱 최하단 배경(스크린).",
        "value": { "light": "{primitive.color.gray.50}", "dark": "{primitive.color.gray.900}" }
      },
      "surface": {
        "$description": "카드·시트 기본 표면.",
        "value": { "light": "{primitive.color.white}", "dark": "{primitive.color.gray.800}" }
      },
      "surfaceElevated": {
        "$description": "표면 위 표면(stat 타일·시트 상단).",
