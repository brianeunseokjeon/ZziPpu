      },
      "primary": {
        "$description": "브랜드 주색·주요 액션·활성 탭.",
        "value": { "light": "{primitive.color.blue.400}", "dark": "{primitive.color.blue.500}" }
      },
      "primaryPressed": {
        "value": { "light": "{primitive.color.blue.600}", "dark": "{primitive.color.blue.700}" }
      },
      "onPrimary": {
        "$description": "primary 위 전경(텍스트/아이콘).",
        "value": { "light": "{primitive.color.white}", "dark": "{primitive.color.white}" }
      },
      "primaryTint": {
        "$description": "primary 연한 배경(선택칩·강조 행).",
        "value": { "light": "{primitive.color.blue.50}", "dark": "{primitive.color.blue.700}" }
      },
      "primaryDisabledBg": {
        "$description": "비활성 주요 버튼 배경 — 중립 회색(opacity 곱셈 폐기).",
        "value": { "light": "{primitive.color.gray.200}", "dark": "{primitive.color.gray.700}" }
      },
      "onPrimaryDisabled": {
        "$description": "비활성 버튼 전경 — 의도적 저대비 회색.",
        "value": { "light": "{primitive.color.gray.400}", "dark": "{primitive.color.gray.500}" }
      },
      "textPrimary": {
        "value": { "light": "{primitive.color.gray.900}", "dark": "{primitive.color.gray.50}" }
      },
      "textSecondary": {
        "value": { "light": "{primitive.color.gray.500}", "dark": "{primitive.color.gray.400}" }
      },
      "textTertiary": {
        "$description": "가장 약한 텍스트(플레이스홀더·최약 라벨).",
        "value": { "light": "{primitive.color.gray.400}", "dark": "{primitive.color.gray.500}" }
      },
      "border": {
        "$description": "카드/인풋 외곽선.",
        "value": { "light": "{primitive.color.gray.100}", "dark": "{primitive.color.gray.700}" }
      },
      "borderStrong": {
        "value": { "light": "{primitive.color.gray.200}", "dark": "{primitive.color.gray.600}" }
      },
      "divider": {
        "$description": "리스트 구분선(divide-y).",
        "value": { "light": "{primitive.color.gray.100}", "dark": "{primitive.color.gray.700}" }
      },
      "scrim": {
        "value": { "light": "{primitive.color.black}", "dark": "{primitive.color.black}" },
        "$comment": "opacity는 primitive.opacity.scrim 적용"
      },

      "status": {
        "$description": "정상/주의/경고/정보 3+1 톤. fg=텍스트·아이콘, bg=연한 배경(pill), solid=채움 강조.",
        "success": {
          "fg": { "value": { "light": "{primitive.color.emerald.700}", "dark": "{primitive.color.emerald.400}" } },
          "bg": { "value": { "light": "{primitive.color.emerald.100}", "dark": "{primitive.color.emerald.700}" } },
          "solid": { "value": { "light": "{primitive.color.emerald.400}", "dark": "{primitive.color.emerald.400}" } }
        },
        "warning": {
          "$comment": "'주의'. 게이지 부족·오프라인 대기.",
          "fg": { "value": { "light": "{primitive.color.amber.700}", "dark": "{primitive.color.amber.400}" } },
          "bg": { "value": { "light": "{primitive.color.amber.100}", "dark": "{primitive.color.amber.700}" } },
          "solid": { "value": { "light": "{primitive.color.amber.400}", "dark": "{primitive.color.amber.400}" } }
        },
        "danger": {
          "$comment": "'경고'. 게이지 초과·붉은 대변·파괴적 액션.",
          "fg": { "value": { "light": "{primitive.color.rose.700}", "dark": "{primitive.color.rose.400}" } },
          "bg": { "value": { "light": "{primitive.color.rose.100}", "dark": "{primitive.color.rose.700}" } },
          "solid": { "value": { "light": "{primitive.color.red.400}", "dark": "{primitive.color.red.400}" } }
        },
        "info": {
          "fg": { "value": { "light": "{primitive.color.blue.700}", "dark": "{primitive.color.blue.100}" } },
          "bg": { "value": { "light": "{primitive.color.blue.100}", "dark": "{primitive.color.blue.700}" } },
          "solid": { "value": { "light": "{primitive.color.blue.500}", "dark": "{primitive.color.blue.500}" } }
        }
      },

      "domain": {
        "$description": "도메인 기록 색. 타임라인 도트·칩·배지·차트가 공유. PRODUCT_SPEC + DayTimeline DOTS + constants 근거. 다크에서도 채도 유지(도트 식별성).",
        "feeding": {
          "formula": {
            "$comment": "분유",
